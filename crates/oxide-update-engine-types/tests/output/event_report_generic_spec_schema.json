      "type": "array",
      "items": {
        "$ref": "#/definitions/ProgressEventForGenericSpec"
      }
    },
    "root_execution_id": {
      "description": "The root execution ID for this report.",
      "anyOf": [
        {
          "$ref": "#/definitions/ExecutionUuid"
        },
